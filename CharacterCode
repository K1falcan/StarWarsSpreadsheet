import urllib.request
import json
from openpyxl import load_workbook
from openpyxl.styles import Font, PatternFill, Alignment, Border, Side

# ── Fetch all characters from swapi.info ──
url = "https://swapi.info/api/people"
req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
with urllib.request.urlopen(req) as response:
    people = json.loads(response.read().decode())

# ── Load your existing workbook ──
wb = load_workbook("star_wars_order.xlsx")
ws = wb.create_sheet(title="Characters")

# ── Styles (exact match to MainCode.py) ──
gold_fill  = PatternFill("solid", start_color="FFD700", end_color="FFD700")
dark_fill  = PatternFill("solid", start_color="1A1A2E", end_color="1A1A2E")
alt_fill   = PatternFill("solid", start_color="2E2E4E", end_color="2E2E4E")
title_font = Font(name="Arial", bold=True, color="FFFFFF", size=14)
data_font  = Font(name="Arial", color="FFFFFF", size=11)
center     = Alignment(horizontal="center", vertical="center")
thin_border = Border(
    left=Side(style="thin", color="FFD700"),
    right=Side(style="thin", color="FFD700"),
    top=Side(style="thin", color="FFD700"),
    bottom=Side(style="thin", color="FFD700")
)

def style_header(cell):
    cell.fill = gold_fill
    cell.font = Font(name="Arial", bold=True, color="1A1A2E", size=12)
    cell.alignment = center
    cell.border = thin_border

def style_data(cell, row_idx):
    cell.fill = dark_fill if row_idx % 2 == 0 else alt_fill
    cell.font = data_font
    cell.alignment = center
    cell.border = thin_border

# ── Fields to display for each character ──
fields = ["name", "height", "mass", "hair_color",
          "skin_color", "eye_color", "birth_year", "gender"]

# ── Write all character tables to the same tab ──
current_row = 1

for person in people:

    # ── Title row ──
    ws.merge_cells(f"A{current_row}:B{current_row}")
    ws[f"A{current_row}"] = person["name"]
    ws[f"A{current_row}"].fill = PatternFill("solid", start_color="4A0000", end_color="4A0000")
    ws[f"A{current_row}"].font = title_font
    ws[f"A{current_row}"].alignment = center
    ws[f"A{current_row}"].border = thin_border
    ws.row_dimensions[current_row].height = 24
    current_row += 1

    # ── Header row ──
    ws[f"A{current_row}"] = "Field"
    ws[f"B{current_row}"] = "Value"
    style_header(ws[f"A{current_row}"])
    style_header(ws[f"B{current_row}"])
    ws.row_dimensions[current_row].height = 24
    current_row += 1

    # ── Data rows ──
    for i, field in enumerate(fields):
        value = person.get(field, "unknown")
        ws.cell(row=current_row, column=1, value=field.replace("_", " ").title())
        ws.cell(row=current_row, column=2, value=value)
        style_data(ws.cell(row=current_row, column=1), i)
        style_data(ws.cell(row=current_row, column=2), i)
        ws.row_dimensions[current_row].height = 24
        current_row += 1

    # ── Gap row between characters ──
    current_row += 1

# ── Column widths ──
ws.column_dimensions["A"].width = 18
ws.column_dimensions["B"].width = 28
ws.sheet_view.showGridLines = False

wb.save("star_wars_order.xlsx")
print("Character tab added successfully!")